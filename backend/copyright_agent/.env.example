BRAVE_API_KEY=
SERPER_API_KEY=
TAVILY_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=

APP_TITLE=Inspiration Safety Advisor
APP_VERSION=2.0.0
COPYRIGHT_CHECK_ROUTE=/check-copyright
LOG_LEVEL=INFO

SEARCH_PROVIDER_PRIORITY=brave,serper,tavily
SEARCH_TIMEOUT_SECONDS=8
BRAVE_SEARCH_URL=https://api.search.brave.com/res/v1/web/search
BRAVE_SEARCH_COUNT=5
SERPER_SEARCH_URL=https://google.serper.dev/search
SERPER_SEARCH_COUNT=5
TAVILY_SEARCH_URL=https://api.tavily.com/search
TAVILY_MAX_RESULTS=5
TAVILY_SEARCH_DEPTH=basic

GEMINI_MODEL=gemini-2.5-flash
GEMINI_RETRIES=3
GEMINI_BACKOFF_MAX_SECONDS=4

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=song_lyrics
EMBEDDING_MODEL=all-MiniLM-L6-v2

LOCAL_SONGS_PATH=
PUBLIC_DOMAIN_PHRASES_PATH=
PUBLIC_DOMAIN_SONGS_PATH=

INPUT_TITLE_OR_PHRASE_MAX_WORDS=3
INPUT_SHORT_LYRIC_MAX_WORDS=10
INPUT_ANALYSIS_CONFIDENCE=0.95

EVIDENCE_BASE_CONFIDENCE=0.35
EVIDENCE_SOURCE_WEIGHT=0.12
EVIDENCE_SOURCE_RATIO_WEIGHT=0.40
EVIDENCE_MAX_CONFIDENCE=0.99
EVIDENCE_LOCAL_CONFIDENCE=0.97
EVIDENCE_LOCAL_URL_PREFIX=local://

LLM_EVIDENCE_OVERRIDE_CONFIDENCE=0.95

RISK_HIGH_CONFIDENCE=0.95
RISK_MEDIUM_CONFIDENCE=0.75
RISK_LOW_CONFIDENCE=0.40
PUBLIC_DOMAIN_CONFIDENCE=0.98
ORIGINAL_CONFIDENCE_FLOOR=0.91
RISK_MAX_CONFIDENCE=0.99

REQUIRE_EXTERNAL_SERVICE_KEYS=false
